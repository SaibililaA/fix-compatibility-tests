xfmtutil.1: fmtutil.help2man $(tl_scripts_dir)/fmtutil.pl
	help2man --include=$< --source="TeX Live" --no-info \
	  $(tl_scripts_dir)/fmtutil.pl >/tmp/$@
	groff -mandoc -Thtml /tmp/$@ >/tmp/$@.html
