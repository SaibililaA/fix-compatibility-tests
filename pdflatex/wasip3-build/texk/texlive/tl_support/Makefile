xupdmap.1: updmap.help2man $(tl_scripts_dir)/updmap.pl
	help2man --include=$< --source="TeX Live" --no-info \
	  $(tl_scripts_dir)/updmap.pl >/tmp/$@
	groff -mandoc -Thtml /tmp/$@ >/tmp/$@.html
