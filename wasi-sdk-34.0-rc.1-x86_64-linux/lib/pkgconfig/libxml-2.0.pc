prefix=/src/build/toolchain/install
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include
modules=1

Name: libXML
Version: 2.15.2
Description: libXML library version2.
Requires.private: 
Libs: -L${libdir} -lxml2 
Libs.private: -lpthread  -lm   -ldl 
Cflags: -I${includedir}/libxml2  
